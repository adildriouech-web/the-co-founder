# Copy this file to ".env" and fill in your key. Never commit the real .env.

# Required: your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional settings (sensible defaults shown):
# Which model the Co-Founder thinks with. Sonnet = best balance of quality and cost.
#   claude-sonnet-4-6   (recommended for the prototype)
#   claude-opus-4-8     (highest quality, more expensive)
#   claude-haiku-4-5-20251001  (cheapest, fastest, a little less sharp)
MODEL=claude-sonnet-4-6

# Port the app runs on
PORT=3000

# Max length of each reply (keeps replies short and costs low)
MAX_TOKENS=700

# How many recent messages to send to the model each turn (controls cost on long chats)
MAX_HISTORY_TURNS=24

# Durable storage (optional but recommended for production).
# When set, consented conversations + feedback are written to Neon Postgres instead of
# the ephemeral data/*.jsonl files (which reset on every Render redeploy/spin-down).
# Create a free database at https://neon.com and paste its connection string here.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Analytics: token that protects GET /api/stats and the /admin.html dashboard.
# Pick any long random string. If left unset, the stats endpoint stays disabled.
STATS_TOKEN=
